# Security headers
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://connect.facebook.net https://*.google-analytics.com https://*.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://www.facebook.com https://*.google-analytics.com https://*.googletagmanager.com https://*.sanity.io; connect-src 'self' https://*.facebook.com https://*.google-analytics.com https://*.googletagmanager.com https://*.supabase.co https://*.baselayerskin.co https://*.sanity.io; frame-src 'none'

# Cache static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images — subdirectory assets (immutable, 1 year)
/images/*
  Cache-Control: public, max-age=31536000, immutable

/lovable-uploads/*
  Cache-Control: public, max-age=31536000, immutable

# Images — root-level (OG images, logo etc.)
/*.jpg
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

/*.png
  Cache-Control: public, max-age=2592000

# HTML pages
/*.html
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400

# Noindex for checkout
/checkout
  X-Robots-Tag: noindex, nofollow

/checkout/*
  X-Robots-Tag: noindex, nofollow
